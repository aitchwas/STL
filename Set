#include <bits/stdc++.h>
using namespace std;

int main() {
    set<int> s;
    s.insert(40);
    s.insert(10);
    s.insert(30);
    s.insert(20);
    s.insert(10); // duplicate ignored
    cout << "Set elements: ";
    for(int x : s)
        cout << x << " ";
    cout << endl;
    cout << "Size: " << s.size() << endl;
    if(s.find(30) != s.end())
        cout << "30 found\n";
    else
        cout << "30 not found\n";
    s.erase(20);
    cout << "After erase: ";
    for(int x : s)
        cout << x << " ";
    cout << endl;
    cout << "Count of 10: " << s.count(10) << endl;
    auto it1 = s.lower_bound(25);
    cout << "Lower bound of 25: " << *it1 << endl;
    auto it2 = s.upper_bound(30);
    if(it2 != s.end())
        cout << "Upper bound of 30: " << *it2 << endl;
    s.clear();
    cout << "Size after clear: " << s.size() << endl; 
    return 0;
} 
